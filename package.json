{
  "name": "beehivehub-mcp",
  "version": "1.0.0",
  "description": "Servidor MCP Beehive — auth chave→Basic, tools para API Beehive",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --import tsx src/index.ts",
    "start:http": "cross-env MCP_TRANSPORT=http node --import tsx src/index.ts",
    "dev": "npx tsx src/index.ts",
    "dev:http": "cross-env MCP_TRANSPORT=http npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "dotenv": "^17.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=22"
  }
}
